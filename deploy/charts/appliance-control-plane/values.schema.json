{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "appliance-control-plane values",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "replicaCount",
    "image",
    "config",
    "secrets",
    "persistence",
    "service",
    "workspaceStorage"
  ],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "const": 1
    },
    "image": {
      "type": "object",
      "required": [
        "repository",
        "pullPolicy"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      }
    },
    "ui": {
      "type": "object",
      "required": [
        "enabled",
        "image",
        "service",
        "config",
        "resources"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "image": {
          "type": "object",
          "required": [
            "repository",
            "pullPolicy"
          ],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string"
            },
            "digest": {
              "type": "string"
            },
            "pullPolicy": {
              "type": "string",
              "enum": [
                "Always",
                "IfNotPresent",
                "Never"
              ]
            }
          }
        },
        "service": {
          "type": "object",
          "required": [
            "port"
          ],
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          }
        },
        "config": {
          "type": "object",
          "required": [
            "logLevel",
            "cookieSecure"
          ],
          "properties": {
            "logLevel": {
              "type": "string",
              "enum": [
                "debug",
                "info",
                "warn",
                "error"
              ]
            },
            "cookieSecure": {
              "type": "boolean"
            },
            "controlPlaneBaseURL": {
              "type": "string"
            },
            "controlPlaneInternalBaseURL": {
              "type": "string"
            }
          }
        },
        "resources": {
          "type": "object"
        }
      }
    },
    "namespace": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "config": {
      "type": "object",
      "required": [
        "applianceProfile",
        "canonicalOrigin",
        "logLevel",
        "workflowInstanceID"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "applianceProfile": {
                "const": "builder"
              }
            },
            "required": [
              "applianceProfile"
            ]
          },
          "then": {
            "required": [
              "buildCatalog"
            ],
            "properties": {
              "buildCatalog": {
                "$ref": "#/$defs/buildCatalog"
              }
            }
          }
        }
      ],
      "properties": {
        "applianceProfile": {
          "type": "string",
          "enum": [
            "core",
            "builder",
            "storage"
          ]
        },
        "canonicalOrigin": {
          "type": "string",
          "minLength": 1
        },
        "logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        "trustedProxyCount": {
          "type": "integer",
          "minimum": 0
        },
        "workflowInstanceID": {
          "type": "string"
        },
        "buildCatalog": {
          "oneOf": [
            {
              "type": "object",
              "maxProperties": 0
            },
            {
              "$ref": "#/$defs/buildCatalog"
            }
          ]
        }
      }
    },
    "secrets": {
      "type": "object",
      "required": [
        "keysSecretName"
      ],
      "properties": {
        "keysSecretName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "persistence": {
      "type": "object",
      "required": [
        "enabled",
        "accessMode",
        "size",
        "dataDir"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "storageClassName": {
          "type": "string"
        },
        "accessMode": {
          "type": "string",
          "enum": [
            "ReadWriteOnce"
          ]
        },
        "size": {
          "type": "string",
          "minLength": 1
        },
        "dataDir": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "service": {
      "type": "object",
      "required": [
        "publicPort",
        "internalPort"
      ],
      "properties": {
        "publicPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "internalPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "entryPoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "host": {
          "type": "string"
        },
        "tlsSecretName": {
          "type": "string"
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "automountServiceAccountToken": {
          "type": "boolean"
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "traefikNamespaceLabel": {
          "type": "object"
        }
      }
    },
    "workspaceStorage": {
      "type": "object",
      "required": [
        "enabled",
        "accessMode",
        "size",
        "rootDir"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "storageClassName": {
          "type": "string"
        },
        "accessMode": {
          "type": "string",
          "enum": [
            "ReadWriteOnce"
          ]
        },
        "size": {
          "type": "string",
          "minLength": 1
        },
        "rootDir": {
          "type": "string",
          "minLength": 1,
          "pattern": "^/.+"
        }
      }
    }
  },
  "$defs": {
    "catalogName": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,62}$"
    },
    "repoRelativePath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {
          "not": {
            "pattern": "^/"
          }
        },
        {
          "not": {
            "pattern": "\\\\"
          }
        },
        {
          "not": {
            "pattern": "^\\.\\.?$"
          }
        },
        {
          "not": {
            "pattern": "(^|/)\\.(/|$)"
          }
        },
        {
          "not": {
            "pattern": "(^|/)\\.\\.(/|$)"
          }
        }
      ]
    },
    "makeTarget": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}$"
    },
    "imageRepository": {
      "type": "string",
      "pattern": "^[a-z0-9]+([._/-][a-z0-9]+)*$"
    },
    "builderImageDigest": {
      "type": "string",
      "pattern": "^.+@sha256:.+$"
    },
    "buildCatalog": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "required": [
        "buildTargets"
      ],
      "properties": {
        "workProfiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workProfile"
          }
        },
        "repos": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/repo"
          }
        },
        "buildTargets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/buildTarget"
          }
        },
        "workspaceProvisionerImageDigest": {
          "$ref": "#/$defs/builderImageDigest"
        }
      }
    },
    "workProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "repos"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/catalogName"
        },
        "description": {
          "type": "string"
        },
        "repos": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/workProfileRepo"
          }
        }
      }
    },
    "workProfileRepo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/catalogName"
        },
        "enabledByDefault": {
          "type": "boolean"
        }
      }
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "url"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/catalogName"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "defaultRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "buildTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "repo",
        "execution",
        "imageRepository",
        "builderImageDigest"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/catalogName"
        },
        "aliases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/catalogName"
          }
        },
        "description": {
          "type": "string"
        },
        "repo": {
          "$ref": "#/$defs/catalogName"
        },
        "execution": {
          "type": "string",
          "enum": [
            "repo_script",
            "make_target"
          ]
        },
        "scriptPath": {
          "$ref": "#/$defs/repoRelativePath"
        },
        "makeTarget": {
          "$ref": "#/$defs/makeTarget"
        },
        "containerfilePath": {
          "$ref": "#/$defs/repoRelativePath"
        },
        "imageRepository": {
          "$ref": "#/$defs/imageRepository"
        },
        "imageTagTemplate": {
          "type": "string",
          "minLength": 1
        },
        "builderImageDigest": {
          "$ref": "#/$defs/builderImageDigest"
        }
      }
    }
  }
}
