# syntax=docker/dockerfile:1
#
# Built only on the Linux build server/CI, inside the shared dev
# container (see docs/dev-container.md) — never on a developer laptop.

# Build stage: compiles a fully static binary (modernc.org/sqlite is pure
# Go, so CGO_ENABLED=0 needs no libc at all) with the same version/commit/
# build-time ldflags as `make build`. Builds from the vendored module
# tree (-mod=vendor), so this step needs no network access at all.
FROM docker.io/library/golang:1.26 AS build
WORKDIR /src
COPY . .
ARG VERSION=dev
ARG COMMIT=unknown
ARG BUILD_TIME=unknown
RUN CGO_ENABLED=0 go build -mod=vendor \
    -ldflags "-X appliance-code/services/controlplane/internal/version.Version=${VERSION} \
              -X appliance-code/services/controlplane/internal/version.Commit=${COMMIT} \
              -X appliance-code/services/controlplane/internal/version.BuildTime=${BUILD_TIME}" \
    -o /out/appliance-server ./cmd/appliance-server

# Final stage: small Alpine runtime with basic operator/debug ergonomics
# while still staying lean. We keep the runtime to a static Go binary,
# CA bundle, tzdata, and a minimal shell/tooling layer from Alpine.
ARG RUNTIME_PROFILE=debug
FROM alpine:3.24.1
ARG RUNTIME_PROFILE
RUN set -eux; \
    apk add --no-cache \
      bash \
      ca-certificates \
      tzdata; \
    if [ "${RUNTIME_PROFILE}" = "debug" ]; then \
      apk add --no-cache \
        bind-tools \
        curl \
        iproute2 \
        iputils \
        procps \
        vim; \
    elif [ "${RUNTIME_PROFILE}" != "runtime" ]; then \
      echo "unsupported RUNTIME_PROFILE=${RUNTIME_PROFILE}" >&2; \
      exit 1; \
    fi; \
    addgroup -S -g 10001 appliance; \
    adduser -S -D -H -u 10001 -G appliance appliance
COPY --from=build /out/appliance-server /appliance-server
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 0755 /usr/local/bin/entrypoint.sh
USER 10001:10001
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
