# syntax=docker/dockerfile:1
#
# Built only on the Linux build server/CI, inside the shared dev
# container (see docs/dev-container.md) — never on a developer laptop.

# Build stage: compiles a fully static binary (modernc.org/sqlite is pure
# Go, so CGO_ENABLED=0 needs no libc at all) with the same version/commit/
# build-time ldflags as `make build`. Builds from the vendored module
# tree (-mod=vendor), so this step needs no network access at all.
FROM docker.io/library/golang:1.26 AS build
WORKDIR /src
COPY . .
ARG VERSION=dev
ARG COMMIT=unknown
ARG BUILD_TIME=unknown
RUN CGO_ENABLED=0 go build -mod=vendor \
    -ldflags "-X appliance-code/server/backend/internal/version.Version=${VERSION} \
              -X appliance-code/server/backend/internal/version.Commit=${COMMIT} \
              -X appliance-code/server/backend/internal/version.BuildTime=${BUILD_TIME}" \
    -o /out/appliance-server ./cmd/appliance-server

# Final stage: no shell, no package manager, nothing but the static binary,
# a CA bundle (for any outbound HTTPS, e.g. to zot), and tzdata. Runs as the
# same non-root UID the Helm chart's securityContext already assumes.
FROM scratch
COPY --from=build /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=build /usr/share/zoneinfo /usr/share/zoneinfo
COPY --from=build /out/appliance-server /appliance-server
USER 10001:10001
ENTRYPOINT ["/appliance-server"]
