# Copy this file to dev-container/env and edit as needed. This is a
# Makefile fragment (not a shell .env file) that the top-level Makefile
# `-include`s, so every developer can override the dev-container image,
# engine, or cache locations without touching the Makefile or exporting
# env vars by hand. `dev-container/env` itself is gitignored; only this
# example is tracked. Uncomment and edit only the lines you want to
# override; use `VAR = value`, not `VAR ?= value`.

# Container engine binary. Podman is the default; set to "docker" if
# that's what's actually installed.
# CONTAINER_ENGINE = podman

# The Makefile already defaults SUDO to "sudo -n" (non-interactive), since
# `make -C server/backend image` needs the outer dev-shell container to
# be rootful: a rootless outer container only gets one, fully consumed
# user-namespace mapping, so a nested Buildah build inside it can't
# create the additional mapping a real image layer needs. This requires
# a one-time host setup — see docs/dev-container.md for the full
# walkthrough, summarized here:
#   1. sudo visudo -f /etc/sudoers.d/appliance-podman-nopasswd
#      add: <user> ALL=(root) NOPASSWD: /usr/bin/podman   (use `command -v podman` for the exact path)
#   2. sudo podman login ghcr.io   (rootful podman has its own separate credential store)
#
# Only uncomment the line below to turn SUDO *off* — e.g. this host is
# already rootful, or you only use dev-shell/dev-run for plain
# interactive debugging and haven't set up the sudoers rule above.
# SUDO =

# Dev-container image, split into registry/name/tag so CI or a different
# environment can override just the tag (e.g. a PR-built image) without
# repeating the full reference.
# DEV_REGISTRY   = ghcr.io/zoncaesaradmin/development-container
# DEV_IMAGE_NAME = automation-dev
# DEV_IMAGE_TAG  = latest

# Or set the full reference directly, bypassing the three variables above.
# DEV_IMAGE = ghcr.io/zoncaesaradmin/development-container/automation-dev:v0.1.0

# Host directory that persists the Go build/module caches across
# `make dev-shell`/`make dev-run` invocations, so they don't re-download
# modules or recompile from scratch every time (each invocation is
# otherwise a fresh, throwaway container).
# DEV_CACHE_DIR = $(HOME)/.cache/appliance-code-dev

# Bind-mount options appended to every -v flag. Leave empty on Linux/macOS
# without SELinux. On SELinux-enforcing hosts (Fedora, RHEL, CentOS),
# set this to ":Z" so Podman relabels the mounted directories for
# container access.
# DEV_VOLUME_OPTS = :Z
